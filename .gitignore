# ==============================================================================
# .gitignore — SISTAC TFE
# ==============================================================================

# Windows OS artifacts
desktop.ini
Thumbs.db
ehthumbs.db
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
*.ipynb_checkpoints/

# Jupyter Notebooks — checkpoints
.ipynb_checkpoints/

# Data — nunca versionar CVs reales o sintéticos con atributos personales
data/raw/*.jsonl
data/raw/*.csv
data/cleaned/*.jsonl
data/cleaned/*.csv
# Excepción: metadatos del corpus (sin datos personales)
!data/raw/corpus_metadata.json
!data/cleaned/corpus_metadata.json

# Vector store (índices grandes, regenerables)
data/vectorstore/
*.faiss
*.pkl

# Credenciales y claves
.env
*.key
secrets/
openai_key.txt

# Outputs de experimentos (versionar solo los resultados finales curados)
quality_reports/session_logs/
quality_reports/plans/

# Claude Code local files (no compartir entre máquinas)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Word / Office temporales
~$*.docx
~$*.xlsx

# LaTeX (heredado del template — ya no se usa)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib
/.quarto/

# MLflow / experimentos
mlruns/
mlflow.db

# ==============================================================================
# Carpetas del template clo-author no usadas en SISTAC
# ==============================================================================

# Website Quarto del framework (no es SISTAC)
guide/

# Estructura LaTeX (SISTAC usa Word)
paper/preambles/
paper/sections/
paper/quarto/
paper/replication/
paper/supplementary/
paper/talks/

# Scripts R (SISTAC usa solo Python)
scripts/R/

# Documentos fuente grandes — compartir por OneDrive/Drive
master_supporting_docs/**/*.docx
master_supporting_docs/**/*.pdf
master_supporting_docs/**/*.pptx

# Changelog y README del framework original
CHANGELOG.md
README.md

# Logs y planes del autor original del template
quality_reports/session_logs/2026-02-*.md
quality_reports/session_logs/2026-03-*.md
quality_reports/plans/2026-04-09_*.md

# Template de skills del framework (no SISTAC)
templates/skill-template.md

# Reglas LaTeX/R de tablas y figuras (SISTAC usa Word/Excel)
.claude/rules/content-standards.md
